# Non-secret pipeline configuration.
# Edit this file directly (on GitHub or locally) to change search
# behavior, scoring, or logging - no YAML, no workflow file, no
# secrets involved. The GitHub Actions workflows load this file
# automatically and layer real secrets (API keys) on top of it.

# Comma-separated search terms sent to Jooble/Reed/Adzuna.
SEARCH_TERMS=paid media, paid media specialist, paid media manager, senior paid media specialist, paid media executive, paid media coordinator, paid media associate, paid media analyst, paid media lead, paid media director, head of paid media, director of paid media, performance marketing, performance marketing specialist, performance marketing manager, performance marketing executive, performance marketer, performance lead, performance director, director of performance marketing, growth marketing, growth marketer, growth marketing specialist, growth marketing manager, growth lead, head of growth, digital growth manager, acquisition marketing, acquisition marketing manager, customer acquisition manager, customer acquisition specialist, user acquisition manager, user acquisition specialist, digital acquisition manager, media buyer, digital media buyer, programmatic media buyer, media buying specialist, media buying manager, head of media buying, media planner, digital media planner, media planner & buyer, media strategist, digital media strategist, media executive, media specialist, digital media executive, digital media specialist, paid social, paid social specialist, paid social manager, social advertising specialist, social ads specialist, social media advertising specialist, social media manager, social media marketing manager, PPC, PPC specialist, PPC manager, PPC executive, PPC analyst, PPC coordinator, paid search specialist, paid search manager, search marketing specialist, search engine marketing specialist, search engine marketer, SEM specialist, SEM manager, Google Ads specialist, Google Ads manager, Bing Ads specialist, Meta Ads specialist, Facebook Ads specialist, Instagram Ads specialist, TikTok Ads specialist, LinkedIn Ads specialist, Pinterest Ads specialist, Reddit Ads specialist, Snapchat Ads specialist, campaign manager, digital campaign manager, advertising specialist, advertising manager, digital advertising specialist, digital advertising manager, display advertising specialist, display marketing manager, programmatic specialist, programmatic manager, programmatic trader, programmatic campaign manager, demand generation specialist, demand generation manager, digital marketing specialist, digital marketing manager, digital marketing executive, digital marketing associate, digital marketing coordinator, digital marketing analyst, marketing specialist, marketing manager, marketing executive, marketing analyst, marketing operations specialist, ecommerce marketing manager, ecommerce performance manager, conversion marketing manager, CRO specialist, conversion rate optimization specialist, online marketing specialist, online marketing manager, head of performance, head of digital marketing, director of digital marketing

# Optional. Comma-separated terms - any job whose title contains one
# (case-insensitive) is dropped before matching/scoring, regardless of
# what it would otherwise match. Simple substring matching, not fuzzy -
# e.g. "Intern" also excludes "Marketing Internship". Leave blank to
# disable (no jobs excluded).
EXCLUDE_TERMS=

# ISO country codes to search, comma-separated. Reed ignores this
# (UK-only). Adzuna only supports ~20 countries (not Gulf/MENA) - sa,
# kw, and lb are not in Adzuna's supported list and will be skipped
# automatically for that source (not an error) - Jooble still searches
# them normally.
SEARCH_COUNTRIES=gb,us,de,fr,nl,ae,sa,kw,lb,ie,be,ch,pt

TITLE_SCORES_FILE=./config/title_scores.json
FUZZY_MATCH_THRESHOLD=82
ATS_WATCHLIST_FILE=./config/ats_watchlist.json

# Self-service, per-source country exclusion list. Add a country code
# here the moment you see it fail (404) for a specific API - no code
# changes needed, just edit config/country_exclusions.json and commit.
COUNTRY_EXCLUSIONS_FILE=./config/country_exclusions.json
MIN_SCORE=50

DATABASE_PATH=./data/lead_discovery.db
GOOGLE_SERVICE_ACCOUNT_FILE=./credentials/service_account.json

LOG_LEVEL=INFO
LOG_FILE=./logs/lead_discovery.log
